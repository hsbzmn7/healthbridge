# Copy to .env on the server or your machine. Never commit .env.
# See README.md for deployment.

# Required
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER_HOST/?retryWrites=true&w=majority&appName=HealthBridge

# Production: verify Firebase ID tokens (place firebase-service-account.json on the server, not in git).
# Local dev without Firebase: set to true and use X-Dev-User-Id in Postman (see middleware/devAuth.js).
SKIP_FIREBASE=false

# Optional
# PORT=7000

# URL of the Python ML service (same host, Docker network, or private URL in production)
# ML_SERVICE_URL=http://127.0.0.1:5000

# Optional: restrict browser/app origins (comma-separated). If unset, all origins are allowed (typical for local dev + mobile apps).
# CORS_ORIGIN=https://your-web-client.example.com
